---
import Terminal from "../components/Terminal.tsx";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link
			rel="preload"
			href="/fonts/MapleMono-VF.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>rpon %</title>
	</head>
	<body>
		<Terminal client:load />
	</body>
</html>

<style is:global>
	@font-face {
		font-family: "Maple Mono";
		src: url("/fonts/MapleMono-VF.woff2") format("woff2-variations");
		font-weight: 100 900;
		font-style: normal;
		font-display: swap;
	}

	body {
	    font: 20px/1.5 monospace;
		background-color: #272822;
		color: #f8f8f2;
		font-family: "Maple Mono", ui-monospace, SFMono-Regular, Menlo, Monaco,
			Consolas, monospace;
	}

	input,
	textarea,
	select,
	button {
		font: inherit;
		background-color: inherit;
		color: #f8f8f2;
		border: none;
		outline: none;
		caret-shape: block;
	}

	.terminal-input-line {
	  display: flex;
	  align-items: baseline;
	}

	.autocomplete-wrapper {
	  position: relative;
	  flex: 1;
	  min-width: 0;

	  input, .ghost-text {
	    padding: 0px;
	    box-sizing: border-box;
	  }

	  .ghost-text {
	    position: absolute;
	    top: 0; left: 0;
	    color: transparent;        /* hide the typed portion */
	    pointer-events: none;
	    white-space: pre;
	  }

	  .ghost-text .suggestion {
	    color: #aaa;               /* visible suggestion portion */
	  }

	  input {
	    position: relative;
	    background: transparent;
	    width: 100%;
	  }
	}
</style>
